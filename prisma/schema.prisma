// Prisma schema for Marula E-Commerce Platform
// Mobile Solutions (Sales & Rentals) + Marula Oil Products

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["marula"]
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  CUSTOMER

  @@schema("marula")
}

enum ProductCategory {
  MOBILE_SOLUTIONS
  MARULA_OIL

  @@schema("marula")
}

enum ProductSubcategory {
  // Mobile Solutions
  FREEZERS
  TOILETS
  CLINICS
  TRAILERS
  COLD_ROOMS
  ICE
  INSULATED_PANELS
  STEEL_STRUCTURES
  // Marula Oil (pure oil in different sizes)
  MARULA_OIL_RETAIL    // Small bottles for retail (50ml - 500ml)
  MARULA_OIL_WHOLESALE // Larger quantities (1L - 20L)
  MARULA_OIL_BULK      // Bulk/Industrial (drums, tons)

  @@schema("marula")
}

enum OrderStatus {
  PENDING           // Order placed, awaiting payment
  PAID              // Payment received
  PROCESSING        // Order being prepared
  SHIPPED           // Order shipped/out for delivery
  DELIVERED         // Order delivered
  COMPLETED         // Order completed
  CANCELLED         // Order cancelled
  REFUNDED          // Order refunded

  @@schema("marula")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@schema("marula")
}

enum RentalStatus {
  PENDING           // Rental request submitted
  CONFIRMED         // Rental confirmed
  ACTIVE            // Item picked up / in use
  RETURNED          // Item returned
  OVERDUE           // Past return date
  CANCELLED         // Rental cancelled

  @@schema("marula")
}

enum ListingType {
  SALE_ONLY         // Product is only for purchase
  RENTAL_ONLY       // Product is only for rental
  SALE_AND_RENTAL   // Product can be purchased or rented

  @@schema("marula")
}

// ============================================
// USER & AUTH MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Null if using OAuth
  role          Role      @default(CUSTOMER)
  phone         String?

  // Address fields
  address       String?
  city          String?
  province      String?
  postalCode    String?

  // Relations
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  rentals       Rental[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
  @@schema("marula")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("marula")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("marula")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("marula")
}

// ============================================
// PRODUCT MODELS
// ============================================

model Product {
  id              String              @id @default(cuid())
  slug            String              @unique
  name            String
  description     String              @db.Text
  longDescription String?             @db.Text

  // Categorization
  category        ProductCategory
  subcategory     ProductSubcategory?

  // Listing type - determines where product appears
  listingType     ListingType         @default(SALE_ONLY)

  // Pricing (for sale)
  price           Float
  salePrice       Float?

  // Rental pricing (for RENTAL_ONLY or SALE_AND_RENTAL)
  rentalPriceDaily   Float?
  rentalPriceWeekly  Float?
  rentalPriceMonthly Float?
  rentalDeposit      Float?

  // Inventory
  sku             String?
  stockQuantity   Int                 @default(0)
  rentalQuantity  Int                 @default(0)  // Units available for rent

  // Shipping
  weightKg        Float?
  requiresDeliveryQuote Boolean       @default(false)

  // Status
  isActive        Boolean             @default(true)
  isFeatured      Boolean             @default(false)

  // Relations
  images          ProductImage[]
  specs           ProductSpec[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  rentals         Rental[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("products")
  @@schema("marula")
}

model ProductImage {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Cloudinary/UploadThing storage
  url           String
  publicId      String?  // For deletion
  thumbnailUrl  String?

  // Metadata
  altText       String?
  caption       String?

  // Ordering
  isPrimary     Boolean  @default(false)
  sortOrder     Int      @default(0)

  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([productId, isPrimary])
  @@map("product_images")
  @@schema("marula")
}

model ProductSpec {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  label       String   // e.g., "Dimensions", "Power", "Capacity"
  value       String   // e.g., "2.5m x 1.8m x 2m"
  sortOrder   Int      @default(0)

  @@index([productId])
  @@map("product_specs")
  @@schema("marula")
}

// Product Variants for different sizes/options
model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Size/Option details
  name        String   // e.g., "50ml", "1 Litre", "Small", "2m x 1.5m"
  sku         String?  // Variant-specific SKU

  // Pricing
  price       Float
  salePrice   Float?

  // Rental pricing (for mobile solutions)
  rentalPriceDaily   Float?
  rentalPriceWeekly  Float?
  rentalPriceMonthly Float?

  // Inventory
  stockQuantity   Int   @default(0)
  rentalQuantity  Int   @default(0)

  // Weight for shipping
  weightKg    Float?

  // Status
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  // Relations
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
  @@schema("marula")
}

// ============================================
// ORDER MODELS
// ============================================

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  orderType       String        // 'sale' | 'rental' | 'mixed'
  status          OrderStatus   @default(PENDING)

  // Customer info (supports guest checkout)
  userId          String?       // Null for guest orders
  user            User?         @relation(fields: [userId], references: [id])

  // Guest customer details (always stored for reference)
  customerName    String
  customerEmail   String
  customerPhone   String

  // Shipping/Delivery
  shippingAddress String        @db.Text
  shippingCity    String?
  shippingProvince String?
  shippingPostal  String?
  deliveryNotes   String?       @db.Text

  // Amounts
  subtotal        Float
  shippingCost    Float         @default(0)
  depositTotal    Float         @default(0)  // For rentals
  total           Float

  // Payment
  paystackReference String?
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?

  // Relations
  items           OrderItem[]

  // Admin notes
  adminNotes      String?       @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("orders")
  @@schema("marula")
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  // Snapshot at time of order
  productName     String
  variantName     String?   // e.g., "500ml", "Large"
  productImage    String?

  // Purchase details
  itemType        String    // 'sale' | 'rental'
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  // Rental details (if applicable)
  rentalStart     DateTime?
  rentalEnd       DateTime?
  rentalDays      Int?
  depositAmount   Float?

  // Link to rental record
  rental          Rental?

  @@index([orderId])
  @@map("order_items")
  @@schema("marula")
}

// ============================================
// RENTAL MODEL
// ============================================

model Rental {
  id              String        @id @default(cuid())
  rentalNumber    String        @unique

  orderItemId     String        @unique
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  // Customer (for easy reference)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])

  // Rental period
  startDate       DateTime
  endDate         DateTime

  // Status tracking
  status          RentalStatus  @default(PENDING)

  // Deposit
  depositAmount   Float
  depositReturned Boolean       @default(false)
  depositReturnedAt DateTime?

  // Tracking
  deliveredAt     DateTime?
  returnedAt      DateTime?
  notes           String?       @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([productId, startDate, endDate])
  @@index([status])
  @@map("rentals")
  @@schema("marula")
}

// ============================================
// SETTINGS MODEL
// ============================================

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
  @@schema("marula")
}
